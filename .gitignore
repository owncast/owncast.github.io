# Hugo default output directory
/public

build

# Hugo's place for Generated SCSS
resources/_gen/*

## OS Files
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# OSX
.DS_Store

# Node stuff
node_modules
.vercel

.hugo_build.lock
.docusaurus
.claude

# Contributors data (generated at build time)
.contributors-data.json
.contributors-cache.json
static/img/contributors/
static/images/avatars/

# Releases cache - persisted to reduce GitHub API calls during builds
# .releases-cache.json

# API configuration (generated at build time)
api-config.json

# Environment variables
.env
i18n/

# Local Docmost export prototype (scripts/fetch-docmost.js)
.docmost-preview/

# Generated dev docs synced from Docmost (scripts/fetch-docmost.js).
# index.mdx is the hand-edited landing and IS tracked; everything else here is
# generated and ignored.
dev-docs/*
!dev-docs/index.mdx
src/data/dev-manifest.json
